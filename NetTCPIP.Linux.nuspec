<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
  <metadata>
    <id>NetTCPIP.Linux</id>
    <version>0.4.0</version>
    <authors>peppekerstens</authors>
    <description>PowerShell module for Linux providing cmdlet parity with the Windows NetTCPIP module. Implements Get-NetIPAddress, Get-NetRoute, Get-NetTCPConnection, Get-NetIPConfiguration using ip and ss.</description>
    <tags>PowerShell Linux pwsh Module NetTCPIP</tags>
    <projectUrl>https://github.com/peppekerstens/NetTCPIP.Linux</projectUrl>
    <license type="expression">GPL-3.0-only</license>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
  </metadata>
  <files>
    <file src="NetTCPIP.Linux\**\*" target="NetTCPIP.Linux" />
    <file src="PSScriptAnalyzerSettings.psd1" target="NetTCPIP.Linux" />
  </files>
</package>


